{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "HUSKY=0 npm install && HUSKY=0 npm install --prefix server",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 120,
      "memory": 1024,
      "includeFiles": "server/**"
    }
  }
}
