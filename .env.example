# Default AI provider when UI has no saved preference: openrouter | litellm
AI_PROVIDER=openrouter

# OpenRouter API key for Auto-BI features
OPENROUTER_API_KEY=YOUR_API_KEY_HERE

# LLM model for schema analysis and chart suggestions (OpenRouter)
OPENROUTER_MODEL=qwen/qwen-3-coder-next

# Remote LiteLLM proxy (OpenAI-compatible /v1/chat/completions)
LITELLM_BASE_URL=http://127.0.0.1:4000/v1
LITELLM_API_KEY=YOUR_LITELLM_KEY_HERE
LITELLM_MODEL=gpt-4o-mini

# Express backend port (default: 4000)
PORT=4000

# Secret for encrypting connector secrets at rest (DB passwords, GraphQL tokens/API keys; min 16 chars)
CONNECTOR_SECRET=change-me-to-a-long-random-string
