# Neon PostgreSQL (required for Vercel / core deployment)
# Create a project at https://neon.tech and copy the pooled connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Feature mode: core (Vercel + Neon) | full (Vercel/Neon + all APIs)
TINIX_FEATURES=full

# Disable Husky on Vercel builds
HUSKY=0

# Default AI provider when UI has no saved preference: openrouter | litellm
AI_PROVIDER=openrouter

# Auto-BI (OpenRouter or LiteLLM)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen-3-coder-next
LITELLM_BASE_URL=
LITELLM_API_KEY=
LITELLM_MODEL=gpt-4o-mini

# Data connectors — encrypts passwords/tokens at rest (min 16 chars)
CONNECTOR_SECRET=

# Embed publishing — JWT signing (min 32 chars)
EMBED_JWT_SECRET=
EMBED_TOKEN_TTL_SECONDS=300

# Agent API — JWT signing (falls back to EMBED_JWT_SECRET)
AGENT_JWT_SECRET=
AGENT_TOKEN_TTL_SECONDS=300

# Optional build-time frontend feature hint (requires rebuild to toggle)
# VITE_TINIX_FEATURES=full
